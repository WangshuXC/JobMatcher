## 2. 核心类型定义

```typescript
// 职位数据（最终存储单元）
interface JobPosting {
  id: string;              // 唯一标识：`${source.id}_${sourceId}`
  title: string;           // 职位名称
  company: string;         // 公司名称
  source: string;          // 数据源标识（如 "bytedance"）
  location: string;        // 工作地点（多个用"、"分隔）
  sourceId: string;        // 原始平台职位 ID
  description: string;     // 职位描述/职责
  requirements: string;    // 职位要求
  detailUrl: string;       // 详情页 URL
  crawledAt: string;       // 抓取时间 ISO 格式
  category?: string;       // 职位类别
  salary?: string;         // 薪资范围（如有）
}

// 数据源配置
interface CrawlerSource {
  id: string;              // 唯一标识（小写英文，如 "meituan"）
  name: string;            // 显示名称（如 "美团"）
  company: string;         // 公司名称
  logo?: string;           // Logo URL（favicon）
  baseUrl: string;         // 招聘网站基础 URL
  enabled: boolean;        // 是否启用
  description: string;     // 描述信息
}

// 岗位分类（两级结构）
interface JobCategory {
  id: string;              // 大类 ID
  name: string;            // 大类名称
  subCategories: SubCategory[];  // 可为空数组（如腾讯的部分大类无子分类）
}
interface SubCategory {
  id: string;              // 子分类 ID
  name: string;            // 子分类名称
}
```

